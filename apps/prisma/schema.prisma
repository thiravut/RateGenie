generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// === Enums ===

enum Role {
  OWNER
  REVENUE_MANAGER
  FRONT_DESK
  SYSTEM_ADMIN
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum OtaConnectionStatus {
  CONNECTED
  ERROR
  DISCONNECTED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  MODIFIED
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum RecommendationStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum RejectionReason {
  LOCAL_EVENT
  PRICE_TOO_HIGH
  PRICE_TOO_LOW
  MARKET_KNOWLEDGE
  OTHER
}

// === Models (Epic 1) ===

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  name                String
  passwordHash        String
  role                Role      @default(OWNER)
  notificationChannel String?
  lineUserId          String?
  telegramChatId      String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  ownedHotels      Hotel[]          @relation("HotelOwner")
  hotelAccess      HotelUser[]
  sentInvitations  Invitation[]     @relation("InvitationSender")
  decisions        Recommendation[] @relation("RecommendationDecider")
  auditLogs          AuditLog[]         @relation("AuditUser")
  verificationCodes  VerificationCode[]
}

model Hotel {
  id         String    @id @default(uuid())
  name       String
  location   String?
  totalRooms Int       @default(0)
  ownerId    String
  owner      User      @relation("HotelOwner", fields: [ownerId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  members        HotelUser[]
  invitations    Invitation[]
  otaConnections  OtaConnection[]
  roomTypes       RoomType[]
  rateSnapshots   RateSnapshot[]
  bookings        Booking[]
  syncLogs        SyncLog[]
  recommendations Recommendation[]
  auditLogs       AuditLog[]
}

model HotelUser {
  id        String   @id @default(uuid())
  userId    String
  hotelId   String
  role      Role
  user      User     @relation(fields: [userId], references: [id])
  hotel     Hotel    @relation(fields: [hotelId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, hotelId])
}

model Invitation {
  id        String           @id @default(uuid())
  email     String
  hotelId   String
  role      Role
  status    InvitationStatus @default(PENDING)
  senderId  String
  sender    User             @relation("InvitationSender", fields: [senderId], references: [id])
  hotel     Hotel            @relation(fields: [hotelId], references: [id])
  expiresAt DateTime
  createdAt DateTime         @default(now())

  @@unique([email, hotelId])
}

// === Models (Epic 2) ===

model OtaConnection {
  id                String              @id @default(uuid())
  hotelId           String
  hotel             Hotel               @relation(fields: [hotelId], references: [id])
  otaName           String
  channexPropertyId String
  status            OtaConnectionStatus @default(CONNECTED)
  lastSyncAt        DateTime?
  lastError         String?
  retryCount        Int                 @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([hotelId, otaName])
}

model RoomType {
  id                 String   @id @default(uuid())
  hotelId            String
  hotel              Hotel    @relation(fields: [hotelId], references: [id])
  name               String
  minPrice           Int?
  maxPrice           Int?
  maxDiscountPercent Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  otaMappings     OtaRoomMapping[]
  rateSnapshots   RateSnapshot[]
  bookings        Booking[]
  recommendations Recommendation[]
}

model OtaRoomMapping {
  id            String   @id @default(uuid())
  roomTypeId    String
  roomType      RoomType @relation(fields: [roomTypeId], references: [id])
  otaName       String
  otaRoomTypeId String
  otaRoomName   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([roomTypeId, otaName])
}

model RateSnapshot {
  id         String   @id @default(uuid())
  roomTypeId String
  roomType   RoomType @relation(fields: [roomTypeId], references: [id])
  hotelId    String
  hotel      Hotel    @relation(fields: [hotelId], references: [id])
  otaName    String
  date       DateTime @db.Date
  price      Int
  currency   String   @default("THB")
  syncedAt   DateTime @default(now())

  @@unique([roomTypeId, otaName, date])
  @@index([hotelId, date])
}

model Booking {
  id               String        @id @default(uuid())
  hotelId          String
  hotel            Hotel         @relation(fields: [hotelId], references: [id])
  channexBookingId String?       @unique
  otaName          String
  roomTypeId       String?
  roomType         RoomType?     @relation(fields: [roomTypeId], references: [id])
  guestName        String?
  checkIn          DateTime      @db.Date
  checkOut         DateTime      @db.Date
  status           BookingStatus @default(CONFIRMED)
  totalPrice       Int
  currency         String        @default("THB")
  rawData          Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([hotelId, checkIn])
}

model SyncLog {
  id          String      @id @default(uuid())
  hotelId     String
  hotel       Hotel       @relation(fields: [hotelId], references: [id])
  otaName     String
  syncType    String
  status      SyncStatus
  error       String?
  itemCount   Int         @default(0)
  startedAt   DateTime    @default(now())
  completedAt DateTime?
}

// === Models (Epic 3) ===

model Recommendation {
  id               String               @id @default(uuid())
  hotelId          String
  hotel            Hotel                @relation(fields: [hotelId], references: [id])
  roomTypeId       String
  roomType         RoomType             @relation(fields: [roomTypeId], references: [id])
  targetDate       DateTime             @db.Date
  currentPrice     Int
  recommendedPrice Int
  changePercent    Float
  changeDirection  String
  reason           String
  status           RecommendationStatus @default(PENDING)
  rejectionReason  RejectionReason?
  rejectionNote    String?
  decidedAt        DateTime?
  decidedById      String?
  decidedBy        User?                @relation("RecommendationDecider", fields: [decidedById], references: [id])
  expiresAt        DateTime
  createdAt        DateTime             @default(now())

  @@index([hotelId, status])
  @@index([hotelId, targetDate])
}

model AuditLog {
  id         String   @id @default(uuid())
  hotelId    String
  hotel      Hotel    @relation(fields: [hotelId], references: [id])
  userId     String?
  user       User?    @relation("AuditUser", fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  details    Json?
  createdAt  DateTime @default(now())

  @@index([hotelId, createdAt])
}

// === Models (Epic 4) ===

model VerificationCode {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  channel   String
  code      String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}
